rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitives & Helpers
    // ===============================================================
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && uid == request.auth.uid; }
    function signedInEmail() { return request.auth.token.email; }
    function isProjectCollaborator(data) {
      return isSignedIn() && (
        data.initiatorUid == request.auth.uid ||
        (data.support is list && signedInEmail() in data.support)
      );
    }
    
    // Admin check: either in admins collection or a hardcoded bootstrap admin
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "luxueying645@gmail.com" && request.auth.token.email_verified == true)
      ); 
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) && 
             data.keys().size() == 4 && // uid, email, role, displayName
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'initiatorUid', 'createdAt', 'lastUpdated']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.initiatorUid == request.auth.uid &&
             data.createdAt is int &&
             data.lastUpdated is int;
    }

    function isValidDataset(data) {
      return data.keys().hasAll(['name', 'creatorUid', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.creatorUid == request.auth.uid &&
             data.createdAt is int &&
             data.updatedAt is int;
    }

    function isValidTemplate(data) {
      return data.keys().hasAll(['name', 'paradigm', 'creatorUid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.paradigm in ['GSB', 'MOS', 'Arena', 'Arena-rank'] &&
             data.creatorUid == request.auth.uid &&
             data.createdAt is int;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['name', 'datasetId', 'templateId', 'status', 'creatorUid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.datasetId is string &&
             data.templateId is string &&
             data.status in ['draft', 'active', 'completed'] &&
             data.creatorUid == request.auth.uid &&
             data.createdAt is int;
    }

    function isValidVoteDocument(data) {
      return data.keys().hasOnly(['votes']) &&
             data.votes is list &&
             data.votes.size() <= 500;
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isVerifiedUser();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isSignedIn() && userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) &&
                    incoming().displayName is string && incoming().displayName.size() <= 50;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          isProjectCollaborator(existing()) &&
          incoming().initiatorUid == existing().initiatorUid &&
          incoming().createdAt == existing().createdAt &&
          incoming().lastUpdated is int &&
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'category', 'priority', 'type', 'goal', 'cycle',
            'support', 'progress', 'steps', 'datasetIds', 'dimensions',
            'lastUpdated', 'link', 'resultSummary', 'generatedDataStatus',
            'analysis'
          ])
        )
      );
      allow delete: if isAdmin() || isOwner(existing().initiatorUid);
    }

    // Legacy UI list (DatasetList) — lightweight dataset rows
    match /datasets/{datasetId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(datasetId) &&
        incoming().keys().hasAll(['name', 'creatorUid', 'createdAt']) &&
        incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 100 &&
        incoming().creatorUid == request.auth.uid &&
        incoming().createdAt is int;
      allow update, delete: if isSignedIn() && (
        isAdmin() || existing().creatorUid == request.auth.uid
      );
    }

    match /evalDatasets/{datasetId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(datasetId) && isValidDataset(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          existing().creatorUid == request.auth.uid &&
          incoming().creatorUid == existing().creatorUid &&
          incoming().createdAt == existing().createdAt &&
          incoming().updatedAt is int &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'tags', 'inputSchema', 'inputType', 'items', 'updatedAt'])
        )
      );
      allow delete: if isAdmin() || isOwner(existing().creatorUid);
    }

    match /evalTemplates/{templateId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(templateId) && isValidTemplate(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          existing().creatorUid == request.auth.uid &&
          incoming().creatorUid == existing().creatorUid &&
          incoming().createdAt == existing().createdAt &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'paradigm', 'dimensions'])
        )
      );
      allow delete: if isAdmin() || isOwner(existing().creatorUid);
    }

    match /evalTasks/{taskId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming()) &&
                    (incoming().datasetId == 'external-csv' ||
                     exists(/databases/$(database)/documents/evalDatasets/$(incoming().datasetId))) &&
                    exists(/databases/$(database)/documents/evalTemplates/$(incoming().templateId));
      allow update: if isSignedIn() && (
        isAdmin() || (
          // Creator can update everything except immutable fields
          existing().creatorUid == request.auth.uid &&
          incoming().creatorUid == existing().creatorUid &&
          incoming().createdAt == existing().createdAt &&
          existing().status != 'completed' && // Locked if completed
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'projectId', 'datasetId', 'templateId', 'models', 'outputType', 'status', 'assignees', 'progress', 'totalItems', 'hasImportedData', 'externalResultsLink'])
        ) || (
          // Assignees can update ONLY progress (assignees are stored as emails)
          existing().status == 'active' &&
          request.auth.token.email_verified == true &&
          request.auth.token.email != null &&
          request.auth.token.email in existing().assignees &&
          incoming().diff(existing()).affectedKeys().hasOnly(['progress'])
        )
      );
      allow delete: if isAdmin() || isOwner(existing().creatorUid);

      match /items/{itemId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          get(/databases/$(database)/documents/evalTasks/$(taskId)).data.creatorUid == request.auth.uid;
        allow update, delete: if isSignedIn() &&
          get(/databases/$(database)/documents/evalTasks/$(taskId)).data.creatorUid == request.auth.uid;
      }

      match /userVotes/{userUid} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create, update: if isSignedIn() && userUid == request.auth.token.email && isValidVoteDocument(incoming()) &&
                      get(/databases/$(database)/documents/evalTasks/$(taskId)).data.status == 'active';
        allow delete: if isAdmin();
      }
    }
  }
}
