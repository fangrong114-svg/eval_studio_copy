{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Evaluation Project",
      "description": "High-level container for evaluation tasks.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "type": { "type": "string" },
        "initiatorUid": { "type": "string" },
        "initiatorName": { "type": "string" },
        "goal": { "type": "string" },
        "cycle": { "type": "string" },
        "support": { "type": "array", "items": { "type": "string" } },
        "progress": { "type": "number" },
        "steps": { "type": "array", "items": { "type": "object" } },
        "datasetIds": { "type": "array", "items": { "type": "string" } },
        "dimensions": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "number" },
        "lastUpdated": { "type": "number" }
      },
      "required": ["name", "initiatorUid", "createdAt", "lastUpdated"]
    },
    "Dataset": {
      "title": "Evaluation Dataset",
      "description": "Metadata and items for model evaluation.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "inputSchema": { "type": "array", "items": { "type": "object" } },
        "items": { "type": "array", "items": { "type": "object" } },
        "creatorUid": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "creatorUid", "createdAt", "updatedAt"]
    },
    "Template": {
      "title": "Evaluation Template",
      "description": "Definition of evaluation dimensions and paradigms.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "paradigm": { "type": "string", "enum": ["GSB", "MOS", "Arena"] },
        "dimensions": { "type": "array", "items": { "type": "object" } },
        "creatorUid": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "paradigm", "creatorUid", "createdAt"]
    },
    "Task": {
      "title": "Evaluation Task",
      "description": "A specific evaluation run binding a dataset and template.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "projectId": { "type": "string" },
        "datasetId": { "type": "string" },
        "templateId": { "type": "string" },
        "models": { "type": "array", "items": { "type": "object" } },
        "outputType": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "completed"] },
        "assignees": { "type": "array", "items": { "type": "string" } },
        "progress": { "type": "object" },
        "creatorUid": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "datasetId", "templateId", "status", "creatorUid", "createdAt"]
    },
    "Vote": {
      "title": "Vote Record",
      "description": "An individual vote on an evaluation item.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "vote": { "type": "string" },
        "userName": { "type": "string" },
        "userUid": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["itemId", "vote", "userUid", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Evaluation projects."
    },
    "/evalDatasets/{datasetId}": {
      "schema": { "$ref": "#/entities/Dataset" },
      "description": "Reusable datasets."
    },
    "/evalTemplates/{templateId}": {
      "schema": { "$ref": "#/entities/Template" },
      "description": "Reusable evaluation templates."
    },
    "/evalTasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Specific evaluation tasks."
    },
    "/evalTasks/{taskId}/userVotes/{userUid}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "User votes within a task."
    }
  }
}
